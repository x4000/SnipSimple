<Window x:Class="SnipSimple.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross"
        KeyDown="Window_KeyDown">

    <Canvas x:Name="OverlayCanvas" Background="Transparent">
        <!-- Frozen snapshot of all screens, used in region mode so the context
             menu that was open when the snip started stays visible (showing it
             live would require activating the overlay, which dismisses menus). -->
        <Image x:Name="BackgroundImage"
               Canvas.Left="0"
               Canvas.Top="0"
               IsHitTestVisible="False"
               Visibility="Collapsed" />

        <!-- Full-canvas dim overlay; hidden once a region drag starts and
             replaced with four edge masks around the selection. -->
        <Rectangle x:Name="FullDim"
                   Canvas.Left="0"
                   Canvas.Top="0"
                   Fill="#40000000"
                   IsHitTestVisible="False" />

        <!-- Selection rectangle drawn in code-behind -->

        <!-- Dimension label -->
        <Border x:Name="DimensionLabel"
                Background="#CC333333"
                CornerRadius="3"
                Padding="6,2"
                Visibility="Collapsed">
            <TextBlock x:Name="DimensionText"
                       Foreground="White"
                       FontSize="12"
                       FontFamily="Segoe UI Variable, Segoe UI" />
        </Border>

        <!-- Window highlight border for window-snip mode -->
        <Border x:Name="WindowHighlight"
                BorderBrush="#0078D4"
                BorderThickness="3"
                Background="#200078D4"
                Visibility="Collapsed"
                IsHitTestVisible="False" />

        <!-- Instruction text -->
        <Border x:Name="InstructionBorder"
                Background="#CC333333"
                CornerRadius="6"
                Padding="16,8">
            <TextBlock x:Name="InstructionText"
                       Foreground="White"
                       FontSize="14"
                       FontFamily="Segoe UI Variable, Segoe UI" />
        </Border>
    </Canvas>
</Window>
