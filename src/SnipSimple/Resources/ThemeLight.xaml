<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light theme colors -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FAFAFA" />
    <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="#F3F3F3" />
    <SolidColorBrush x:Key="ToolbarBorderBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="CanvasBackgroundBrush" Color="#333333" />
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#F3F3F3" />
    <SolidColorBrush x:Key="StatusBarBorderBrush" Color="#E0E0E0" />

    <SolidColorBrush x:Key="PrimaryBrush" Color="#0078D4" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#106EBE" />

    <SolidColorBrush x:Key="SurfaceBrush" Color="#F3F3F3" />
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#E5E5E5" />
    <SolidColorBrush x:Key="SurfacePressedBrush" Color="#D1D1D1" />

    <SolidColorBrush x:Key="TextBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#666666" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#999999" />

    <SolidColorBrush x:Key="ControlBorderBrush" Color="#D1D1D1" />
    <SolidColorBrush x:Key="SwatchBorderBrush" Color="#CCCCCC" />

    <SolidColorBrush x:Key="CheckBoxForegroundBrush" Color="#666666" />

</ResourceDictionary>
